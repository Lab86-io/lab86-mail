{
  "$schema": "https://biomejs.dev/schemas/2.4.1/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": ["**/*", "!**/.next/**", "!**/node_modules/**", "!**/data/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 110
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off"
      },
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  }
}
