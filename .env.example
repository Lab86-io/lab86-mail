# lab86-mail — hosted (Railway + Convex) environment reference.
# Values live in Railway service variables; this file documents the surface.

# --- Core services -----------------------------------------------------------
NEXT_PUBLIC_CONVEX_URL=
LAB86_CONVEX_INTERNAL_SECRET=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# e.g. https://mail.lab86.io (prod) / https://mail-staging.lab86.io (development)
LAB86_MAIL_PUBLIC_URL=

# --- Nylas -------------------------------------------------------------------
NYLAS_API_KEY=
NYLAS_CLIENT_ID=
NYLAS_CLIENT_SECRET=
# HMAC secret issued when the webhook destination is created in the Nylas
# dashboard. REQUIRED in production: without it /api/nylas/webhook rejects all
# deliveries (set LAB86_MAIL_ALLOW_UNVERIFIED_WEBHOOKS=1 only for local dev).
NYLAS_WEBHOOK_SECRET=
# LAB86_MAIL_ALLOW_UNVERIFIED_WEBHOOKS=1

# --- Providers ---------------------------------------------------------------
# iCloud rollout: hidden (default) | disabled | beta | enabled.
# beta/enabled shows the connect button; it stays disabled until the Nylas
# iCloud connector exists and LAB86_MAIL_NYLAS_ICLOUD_CONNECTOR_READY=1.
# LAB86_MAIL_ICLOUD_MODE=beta
# LAB86_MAIL_NYLAS_ICLOUD_CONNECTOR_READY=1

# --- Search tiers ------------------------------------------------------------
# Local (Convex corpus) search is the default for all providers once the
# corpus is backfilled. Override per provider when debugging:
# LAB86_MAIL_LOCAL_SEARCH_PROVIDERS=google,microsoft,icloud,imap
# LAB86_MAIL_LOCAL_SEARCH_DISABLED_PROVIDERS=
# LAB86_MAIL_LOCAL_SEARCH_GOOGLE=1

# --- AI ----------------------------------------------------------------------
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LAB86_MAIL_OPENAI_MODEL=gpt-5.5
# LAB86_MAIL_OPENAI_FAST_MODEL=gpt-5.4-mini

# --- Billing -----------------------------------------------------------------
# CLERK_PRO_PLAN_SLUG=mail_pro
# CLERK_ADMIN_PLAN_SLUG=admin
# Both URLs also accept NEXT_PUBLIC_-prefixed variants
# (NEXT_PUBLIC_CLERK_BILLING_CHECKOUT_URL / NEXT_PUBLIC_CLERK_BILLING_PORTAL_URL).
# CLERK_BILLING_CHECKOUT_URL=
# CLERK_BILLING_PORTAL_URL=
