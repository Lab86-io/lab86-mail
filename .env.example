# mail-os v2 — environment overrides
# Place in /home/jjalangtry/.config/mail-os/mail-os.env (loaded via systemd EnvironmentFile)

# Listen address (defaults: 127.0.0.1:18836)
PORT=18836
HOSTNAME=127.0.0.1

# Comma-separated list of accounts surfaced in the rail before GOG discovery.
MAIL_OS_ACCOUNTS=jjalangtry@gmail.com,jakob@lab86.io

# GOG binary (defaults to /home/jjalangtry/.local/bin/lab86-gog)
MAIL_OS_GOG_BIN=/home/jjalangtry/.local/bin/lab86-gog

# Browserbase helpers
MAIL_OS_BROWSERBASE_SEARCH=/home/jjalangtry/.local/bin/browserbase-search
MAIL_OS_BROWSERBASE_FETCH=/home/jjalangtry/.local/bin/browserbase-fetch

# Models. Override if GPT-5.5 is unavailable on the OpenAI account.
MAIL_OS_OPENAI_MODEL=gpt-5.5
MAIL_OS_OPENAI_FAST_MODEL=gpt-5.5-mini

# OPENAI_API_KEY is NOT stored here. It comes from a second EnvironmentFile that
# points at /home/jjalangtry/.config/lab86-private/voice-agent.env (shared with voice-agent).

# Where NeDB collections live (default: ./data inside the working directory).
# MAIL_OS_DATA_DIR=/home/jjalangtry/repos/mail-os/data
