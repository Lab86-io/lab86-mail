# lab86-mail — environment overrides
# Place in /home/jjalangtry/.config/lab86-mail/lab86-mail.env (loaded via systemd EnvironmentFile)

# Listen address (defaults: 127.0.0.1:18836)
PORT=18836
HOSTNAME=127.0.0.1

# Comma-separated list of accounts surfaced in the rail before GOG discovery.
LAB86_MAIL_ACCOUNTS=jjalangtry@gmail.com,jakob@lab86.io

# GOG binary (defaults to /home/jjalangtry/.local/bin/lab86-gog)
LAB86_MAIL_GOG_BIN=/home/jjalangtry/.local/bin/lab86-gog

# Browserbase helpers
LAB86_MAIL_BROWSERBASE_SEARCH=/home/jjalangtry/.local/bin/browserbase-search
LAB86_MAIL_BROWSERBASE_FETCH=/home/jjalangtry/.local/bin/browserbase-fetch

# Models. Override if GPT-5.5 is unavailable on the OpenAI account.
LAB86_MAIL_OPENAI_MODEL=gpt-5.5
LAB86_MAIL_OPENAI_FAST_MODEL=gpt-5.5-mini

# OPENAI_API_KEY is NOT stored here. It comes from a second EnvironmentFile that
# points at /home/jjalangtry/.config/lab86-private/voice-agent.env (shared with voice-agent).

# Where NeDB collections live (default: ./data inside the working directory).
# LAB86_MAIL_DATA_DIR=/home/jjalangtry/repos/lab86-mail/data
